#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

SERVICE_NAME="smart_srun"
PROG="/usr/lib/smart_srun/client.py"

find_python() {
	command -v python3 2>/dev/null || command -v python3.11 2>/dev/null
}

start_service() {
	PYTHON_BIN="$(find_python)"
	if [ -z "$PYTHON_BIN" ]; then
		logger -t "$SERVICE_NAME" "python3 not found, please install python3-light"
		return 1
	fi

	procd_open_instance
	procd_set_param command "$PYTHON_BIN" -B "$PROG" daemon
	# retry=0：无限重生。手动动作触发的 restart 叠加曾把 5 次预算烧光，
	# 之后守护进程彻底死透、只能重启路由器。
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

# Only stop the long-running daemon instance.
# CLI/update workers also invoke client.py; killing them mid-install leaves
# update_status.json stuck on "installing" and may orphan the update lock.
is_daemon_cmdline() {
	# cmdline is space-joined; match "client.py daemon" as its own argv tokens.
	case "$1" in
		*"$PROG"\ daemon|*"$PROG"\ daemon\ *)
			return 0
			;;
	esac
	return 1
}

stop_client_processes() {
	for proc in /proc/[0-9]*; do
		[ -r "$proc/cmdline" ] || continue
		cmdline="$(tr '\000' ' ' < "$proc/cmdline" 2>/dev/null)"
		is_daemon_cmdline "$cmdline" || continue
		kill -TERM "${proc##*/}" 2>/dev/null
	done
	sleep 1
	for proc in /proc/[0-9]*; do
		[ -r "$proc/cmdline" ] || continue
		cmdline="$(tr '\000' ' ' < "$proc/cmdline" 2>/dev/null)"
		is_daemon_cmdline "$cmdline" || continue
		kill -KILL "${proc##*/}" 2>/dev/null
	done
}

stop_service() {
	stop_client_processes
	return 0
}
